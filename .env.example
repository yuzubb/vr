# Discord Webhook URL（サーバー設定 > 連携サービス > ウェブフック で作成）
# 注意: このURLは秘密。NEXT_PUBLIC_ を付けず、サーバー側だけで使う
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/yyyyyyyy

# 同期確認スクショの送信間隔（ミリ秒）。既定は30秒
NEXT_PUBLIC_CAPTURE_INTERVAL_MS=30000

# 使用するVRMモデルのパス（public/ からの相対）
NEXT_PUBLIC_VRM_MODEL_URL=/models/avatar.vrm
